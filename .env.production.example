# CodeTube Production Environment Variables
# Copy this file to .env and fill in your actual values
# WARNING: Never commit .env to version control!

# ============================================
# Application Settings
# ============================================
NODE_ENV=production
PORT=3000

# ============================================
# Database Configuration (PostgreSQL)
# ============================================
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# For Docker Compose: postgresql://codetube:YOUR_PASSWORD@postgres:5432/codetube?schema=public
# For managed DB (Railway/Render): Use the connection string provided by the platform
DATABASE_URL=postgresql://codetube:change_me_in_production@postgres:5432/codetube?schema=public

# PostgreSQL Container Settings (only used by docker-compose)
POSTGRES_USER=codetube
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=codetube

# ============================================
# Redis Configuration
# ============================================
# Format: redis://HOST:PORT
# For Docker Compose: redis://redis:6379
# For managed Redis: Use the URL provided by the platform
REDIS_URL=redis://redis:6379

# ============================================
# JWT Authentication
# IMPORTANT: Generate strong secrets using:
#   openssl rand -base64 32
# ============================================
JWT_SECRET=change_this_to_a_random_string_min_32_chars
JWT_REFRESH_SECRET=change_this_to_a_different_random_string
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# ============================================
# CORS Configuration
# Comma-separated list of allowed origins, or '*' for all (not recommended in prod)
# Examples:
#   CORS_ORIGIN=https://yourdomain.com
#   CORS_ORIGIN=https://yourdomain.com,https://www.yourdomain.com
#   CORS_ORIGIN=*
# ============================================
CORS_ORIGIN=https://yourdomain.com

# ============================================
# AI Curriculum Engine
# Provider options: "mock" (no API key needed) | "openai" | "anthropic"
# ============================================
AI_PROVIDER=mock
AI_API_KEY=
AI_MODEL=
# Optional: custom base URL (e.g. for Azure OpenAI, local Ollama)
AI_BASE_URL=

# ============================================
# Fish Audio Voice Synthesis
# Get your API key at https://fish.audio
# ============================================
FISH_AUDIO_API_KEY=
FISH_AUDIO_BASE_URL=https://api.fish.audio/v1

# Voice IDs from Fish Audio (reference_id for each persona)
FISH_VOICE_CHILL=
FISH_VOICE_ENERGETIC=
FISH_VOICE_BRITISH=
FISH_VOICE_SARCASTIC_AUSTRALIAN=
FISH_VOICE_CALM_MENTOR=
FISH_VOICE_ENTHUSIASTIC_TEACHER=
FISH_VOICE_NO_NONSENSE=

# Local directory for generated audio files
AUDIO_STORAGE_DIR=/tmp/codetube-audio

# ============================================
# Optional: External Storage (S3/CloudFront)
# ============================================
STORAGE_ENDPOINT=
STORAGE_BUCKET=codetube
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_REGION=us-east-1

# ============================================
# Optional: Monitoring & Analytics
# ============================================
# SENTRY_DSN=https://...
# GOOGLE_ANALYTICS_ID=G-...

# ============================================
# Optional: Email Service (SendGrid/AWS SES)
# ============================================
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASSWORD=...
# FROM_EMAIL=noreply@yourdomain.com

# ============================================
# Optional: Rate Limiting
# ============================================
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=100
