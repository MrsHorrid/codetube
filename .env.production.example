# CodeTube Production Environment Variables
# Copy this file to .env and fill in your actual values
# WARNING: Never commit .env to version control!

# ============================================
# Application Settings
# ============================================
NODE_ENV=production
PORT=3000

# ============================================
# Database Configuration (PostgreSQL)
# ============================================
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# For Docker Compose: postgresql://codetube:YOUR_PASSWORD@postgres:5432/codetube?schema=public
# For managed DB (Railway/Render): Use the connection string provided by the platform
DATABASE_URL=postgresql://codetube:change_me_in_production@postgres:5432/codetube?schema=public

# PostgreSQL Container Settings (only used by docker-compose)
POSTGRES_USER=codetube
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=codetube

# ============================================
# Redis Configuration
# ============================================
# Format: redis://HOST:PORT
# For Docker Compose: redis://redis:6379
# For managed Redis: Use the URL provided by the platform
REDIS_URL=redis://redis:6379

# ============================================
# JWT Authentication
# ============================================
# IMPORTANT: Generate strong secrets using:
# openssl rand -base64 32
JWT_SECRET=change_this_to_a_random_string_min_32_chars
JWT_REFRESH_SECRET=change_this_to_a_different_random_string
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# ============================================
# Optional: AI/ML Services
# ============================================
# OpenAI API Key for AI-generated content
# OPENAI_API_KEY=sk-...

# ElevenLabs API Key for voice synthesis
# ELEVENLABS_API_KEY=...

# ============================================
# Optional: External Storage (S3/CloudFront)
# ============================================
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=us-east-1
# S3_BUCKET_NAME=codetube-uploads
# CDN_BASE_URL=https://cdn.yourdomain.com

# ============================================
# Optional: Monitoring & Analytics
# ============================================
# SENTRY_DSN=https://...
# GOOGLE_ANALYTICS_ID=G-...

# ============================================
# Optional: Email Service (SendGrid/AWS SES)
# ============================================
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASSWORD=...
# FROM_EMAIL=noreply@yourdomain.com

# ============================================
# Optional: Rate Limiting
# ============================================
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=100
